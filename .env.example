# Copy to `.env` and/or `.env.local` (`.env.local` overrides `.env`).

# MongoDB Atlas connection string
MONGO_URI=

# Secret used to sign the session cookie (use a long random string)
COOKIE_KEY=

# Google OAuth (OAuth 2.0 Client — Web application)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public URL of this server (no trailing slash). Must match the authorized redirect URI in Google Cloud:
# {BASE_URL}/auth/google/callback
BASE_URL=http://localhost:4000

# Optional: if OAuth redirect should use a different origin than BASE_URL
# GOOGLE_CALLBACK_BASE=http://localhost:4000

# Optional: comma-separated allowlist (defaults to the two family emails in code)
# ALLOWED_EMAILS=13daer@gmail.com,i.s.gaponova@gmail.com

# Required for a hosted SPA: exact frontend origin(s), comma-separated. Must match axios `withCredentials: true` + CORS.
# Multiple: CORS_ORIGIN=http://localhost:5174,https://your-app.vercel.app
# OAuth popup: open `/auth/google?return_origin=<your exact origin>` so postMessage targets that tab (must be listed here).

# PORT=4000

# CDN
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=